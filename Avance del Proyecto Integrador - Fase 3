import socket
import json

from game_logic import Board


def send_json(conn, obj):
    conn.sendall((json.dumps(obj) + "\n").encode())


def recv_json(conn, buf):
    while "\n" not in buf[0]:
        data = conn.recv(4096).decode()

        if not data:
            raise ConnectionError()

        buf[0] += data

    line, buf[0] = buf[0].split("\n", 1)

    return json.loads(line)


class BattleServer:
    def __init__(self):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.bind(('0.0.0.0', 5000))
        self.sock.listen(2)

        self.clients = []
        self.boards = {}

    def start(self):
        print("Esperando 2 jugadores en puerto 5000...")

        while len(self.clients) < 2:
            conn, addr = self.sock.accept()

            buf = [""]

            send_json(conn, {"type": "request_handshake"})

            name = recv_json(conn, buf).get(
                "name",
                f"P{len(self.clients)+1}"
            )

            self.clients.append((conn, name, buf))

            print(f"{name} conectado.")

        play_names = [c[1] for c in self.clients]

        for c, n, b in self.clients:
            send_json(c, {
                "type": "start",
                "players": play_names,
                "your_name": n
            })

            send_json(c, {
                "type": "request",
                "what": "place_fleet"
            })

            msg = recv_json(c, b)

            bd = Board()

            for s in msg['ships']:
                bd.place_ship(tuple(s[0]), tuple(s[1]))

            self.boards[n] = bd

        turn = 0

        while True:
            curr_c, curr_n, curr_b = self.clients[turn]
            opp_n = self.clients[1 - turn][1]

            for c, n, b in self.clients:
                send_json(c, {
                    "type": "state",
                    "your_turn": n == curr_n,
                    "boards": {
                        x: self.boards[x].as_public(n != x)
                        for x in play_names
                    }
                })

            move = recv_json(curr_c, curr_b)['coord']

            res, sunk = self.boards[opp_n].receive_shot(tuple(move))

            for c, n, b in self.clients:
                send_json(c, {
                    "type": "result",
                    "from": curr_n,
                    "coord": move,
                    "result": res
                })

            if self.boards[opp_n].all_sunk():
                for c, n, b in self.clients:
                    send_json(c, {
                        "type": "end",
                        "winner": curr_n
                    })

                break

            turn = 1 - turn


if __name__ == "__main__":
    BattleServer().start()
