# Archivo: client.py

```python
import socket
import json
import argparse

from game_logic import Board


def send_json(c, o):
    c.sendall((json.dumps(o) + "\n").encode())


def recv_json(c, b):
    while "\n" not in b[0]:
        d = c.recv(4096).decode()

        if not d:
            raise ConnectionError()

        b[0] += d

    l, b[0] = b[0].split("\n", 1)

    return json.loads(l)


def get_random_ships():
    b = Board()
    b.random_place_all()

    return [
        [list(min(s)), list(max(s))]
        for s in b.ships
    ]


def run(host, name, auto):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    s.connect((host, 5000))

    b = [""]

    if recv_json(s, b)['type'] == 'request_handshake':
        send_json(s, {
            "type": "handshake",
            "name": name
        })

    print("Esperando inicio...")

    recv_json(s, b)

    if recv_json(s, b)['what'] == 'place_fleet':
        ships = get_random_ships() if auto else []

        send_json(s, {
            "type": "place_fleet",
            "ships": ships
        })

    while True:
        msg = recv_json(s, b)

        if msg['type'] == 'state':
            if msg['your_turn']:
                coord = list(
                    map(
                        int,
                        input("Tu turno (fila col): ").split()
                    )
                )

                send_json(s, {
                    "type": "move",
                    "coord": coord
                })

            else:
                print("Turno del oponente...")

        elif msg['type'] == 'result':
            print(f"Jugada: {msg['result']}")

        elif msg['type'] == 'end':
            print(f"Ganador: {msg['winner']}")
            break


if __name__ == "__main__":
    p = argparse.ArgumentParser()

    p.add_argument("--name", required=True)
    p.add_argument("--auto", action="store_true")

    args = p.parse_args()

    run('127.0.0.1', args.name, args.auto)
```

