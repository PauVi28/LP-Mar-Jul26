# Archivo: game_logic.py

```python
import random

BOARD_SIZE = 10
SHIP_SIZES = [5, 4, 3, 3, 2]

class Board:
    def __init__(self):
        # 0: vacío, 1: barco, 2: impacto, 3: agua
        self.grid = [[0] * BOARD_SIZE for _ in range(BOARD_SIZE)]
        self.ships = []
        self.hits_per_ship = []

    def place_ship(self, start, end):
        r1, c1 = start
        r2, c2 = end
        coords = []

        if r1 == r2:
            step = 1 if c2 >= c1 else -1
            for c in range(c1, c2 + step, step):
                coords.append((r1, c))

        elif c1 == c2:
            step = 1 if r2 >= r1 else -1
            for r in range(r1, r2 + step, step):
                coords.append((r, c1))
        else:
            return False

        if any(not (0 <= r < BOARD_SIZE and 0 <= c < BOARD_SIZE) for r, c in coords):
            return False

        if any(self.grid[r][c] != 0 for r, c in coords):
            return False

        for r, c in coords:
            self.grid[r][c] = 1

        self.ships.append(set(coords))
        self.hits_per_ship.append(0)

        return True

    def random_place_all(self):
        self.ships = []
        self.hits_per_ship = []
        self.grid = [[0] * BOARD_SIZE for _ in range(BOARD_SIZE)]

        for size in SHIP_SIZES:
            placed = False

            while not placed:
                orient = random.choice(['h', 'v'])

                if orient == 'h':
                    r = random.randint(0, BOARD_SIZE - 1)
                    c = random.randint(0, BOARD_SIZE - size)
                    placed = self.place_ship((r, c), (r, c + size - 1))
                else:
                    r = random.randint(0, BOARD_SIZE - size)
                    c = random.randint(0, BOARD_SIZE - 1)
                    placed = self.place_ship((r, c), (r + size - 1, c))

        return True

    def receive_shot(self, coord):
        r, c = coord

        if self.grid[r][c] in [2, 3]:
            return ('repetida', None)

        if self.grid[r][c] == 1:
            self.grid[r][c] = 2

            for idx, ship in enumerate(self.ships):
                if (r, c) in ship:
                    self.hits_per_ship[idx] += 1

                    if self.hits_per_ship[idx] == len(ship):
                        return ('hundido', list(ship))

                    return ('impacto', None)

        self.grid[r][c] = 3
        return ('agua', None)

    def all_sunk(self):
        return all(
            h >= len(s)
            for h, s in zip(self.hits_per_ship, self.ships)
        )

    def as_public(self, hide_ships=True):
        return [
            [
                (0 if (hide_ships and cell == 1) else cell)
                for cell in row
            ]
            for row in self.grid
        ]
