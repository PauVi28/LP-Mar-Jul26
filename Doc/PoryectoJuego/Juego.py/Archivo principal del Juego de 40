from game_logic import iniciar_juego_local
from server import iniciar_servidor
from client import iniciar_cliente

def menu():
    while True:
        print("\n========== JUEGO DE 40 ==========")
        print("1. Modo Local")
        print("2. Multijugador - Servidor")
        print("3. Multijugador - Cliente")
        print("4. Salir")

        opcion = input("Seleccione una opción: ")

        if opcion == "1":
            iniciar_juego_local()

        elif opcion == "2":
            iniciar_servidor()

        elif opcion == "3":
            iniciar_cliente()

        elif opcion == "4":
            print("Saliendo del juego...")
            break

        else:
            print("Opción inválida.")

menu()

