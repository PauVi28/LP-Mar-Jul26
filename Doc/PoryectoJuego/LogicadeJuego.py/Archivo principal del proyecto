import pygame
from ui import mostrar_menu
from game_logic import Game40

pygame.init()

ANCHO = 1280
ALTO = 720

pantalla = pygame.display.set_mode((ANCHO, ALTO))
pygame.display.set_caption("40 Ecuador - Proyecto Integrador")

clock = pygame.time.Clock()

juego = Game40()

ejecutando = True

while ejecutando:

    pantalla.fill((15, 15, 25))

    for evento in pygame.event.get():

        if evento.type == pygame.QUIT:
            ejecutando = False

    mostrar_menu(pantalla)

    pygame.display.flip()
    clock.tick(60)

pygame.quit()

