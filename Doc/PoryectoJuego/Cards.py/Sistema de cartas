class Carta:

    def __init__(self, palo, valor):
        self.palo = palo
        self.valor = valor
    def __str__(self):
        return f"{self.valor} de {self.palo}"

def crear_mazo():
    palos = ["Oros", "Copas", "Espadas", "Bastos"]
    valores = [ "A", "2", "3", "4", "5","6", "7", "10", "11", "12"]

    mazo = []

    for palo in palos:
        for valor in valores:
            carta = Carta(palo, valor)
            mazo.append(carta)
    return mazo
